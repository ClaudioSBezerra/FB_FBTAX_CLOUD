# FBTAX_CLOUD — Portal Hub
# Copiar para .env e preencher com valores reais

# Banco de dados
DB_URL=postgres://user:password@localhost:5432/fbtax_cloud?sslmode=disable
DATABASE_URL=postgres://user:password@localhost:5432/fbtax_cloud?sslmode=disable

# Autenticação JWT (admin)
JWT_SECRET=your-jwt-secret-here-min-32-chars

# SMTP (herdado — services/email.go)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password

# Aplicação
ADMIN_EMAIL=admin@fbtax.cloud
PORT=8083

# CORS (dev: adicionar localhost:5173; prod: apenas www.fbtax.cloud)
ALLOWED_ORIGINS=https://www.fbtax.cloud
